NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Local workspace defaults
NEXT_PUBLIC_LOCAL_USER_NAME=Systematic Tracker
NEXT_PUBLIC_LOCAL_USER_EMAIL=local@systematic-tracker.dev

# Ollama runtime
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_BASE_URL_DOCKER=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:14b-q4_K_M
OLLAMA_FALLBACK_MODEL=qwen3.5:35b-a3b

# Brave-attached preview browser
BRAVE_CDP_URL=http://127.0.0.1:9222
BRAVE_CDP_URL_DOCKER=http://host.docker.internal:9222
BRAVE_RUN_IN_BACKGROUND=true
BRAVE_BRING_TO_FRONT=false
BRAVE_AUTOMATION_PROFILE=automation
BRAVE_USER_PROFILE=user

# Local voice transcription
# The installer downloads Oriserve/Whisper-Hindi2Hinglish-Swift to
# vendor/models/whisper-hindi2hinglish-swift by default.
WHISPER_MODEL_PATH=
WHISPER_LANGUAGE=en
PYTHON_EXECUTABLE=

# Local ChatGPT browser bridge
CHATGPT_BROWSER_PYTHON_EXECUTABLE=.venv\Scripts\python.exe

# Optional services
ARCJET_KEY=
CONVEX_DEPLOYMENT=dev:your-convex-deployment
NEXT_DISABLE_TURBOPACK=1
